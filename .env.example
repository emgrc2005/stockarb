# =============================================================================
# StockArb — environment configuration template
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- Alpaca Paper Trading API -----------------------------------------------
# Generate keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_paper_api_key_id
ALPACA_SECRET_KEY=your_paper_api_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Universe -----------------------------------------------------------------
# Comma-separated ticker list to scan for cointegrated pairs.
# Default below is a liquid basket of US Utilities-sector large caps.
UNIVERSE_TICKERS=NEE,DUK,SO,D,AEP,EXC,XEL,ED,WEC,ES,PEG,EIX,SRE,PPL,FE

# --- Data pipeline --------------------------------------------------------------
DB_PATH=/app/data/stat_arb.db
LOOKBACK_DAYS=756
YFINANCE_MAX_RETRIES=4
YFINANCE_TIMEOUT_SECONDS=30

# --- Analytics engine -----------------------------------------------------------
# Engle-Granger cointegration p-value threshold (lower = stricter)
COINTEGRATION_PVALUE_THRESHOLD=0.05
# ADF test p-value threshold on the spread itself
ADF_PVALUE_THRESHOLD=0.05
# Rolling window (trading days) used to compute the spread z-score
ZSCORE_LOOKBACK_WINDOW=30
# Minimum half-life of mean reversion (days) to accept a pair as tradable
MIN_HALF_LIFE_DAYS=1
MAX_HALF_LIFE_DAYS=45

# --- Execution engine -------------------------------------------------------------
ZSCORE_ENTRY_THRESHOLD=2.0
ZSCORE_EXIT_THRESHOLD=0.5
ZSCORE_STOPLOSS_THRESHOLD=3.5
POSITION_SIZE_USD=2000
MAX_CONCURRENT_PAIRS=5
ALPACA_MAX_RETRIES=4
ALPACA_TIMEOUT_SECONDS=15

# --- Misc -------------------------------------------------------------------------
TIMEZONE=America/New_York
LOG_LEVEL=INFO
